# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key — generate with: python3.10 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Gmail SMTP (used to send account/notification emails)
MAIL_USERNAME=
MAIL_PASSWORD=

# Base URL used to build links in emails (no trailing slash)
APP_BASE_URL=http://localhost:8080
