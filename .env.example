# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key — generate with: python3.10 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Outlook / Office 365 SMTP (used to send account/notification emails)
# MAIL_USERNAME must be the full mailbox address (e.g. noreply@vernay.com)
MAIL_USERNAME=
MAIL_PASSWORD=

# Base URL used to build links in emails (no trailing slash) — must match PORT below
APP_BASE_URL=http://localhost:8080

# Port the app listens on (change if 8080 is already used on this machine)
PORT=8080
