# Copy this file to .env and fill in real values. Never commit .env.

# Flask session signing key — generate with: python3.10 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Microsoft Graph API (used to send account/notification emails via OAuth2 — see App Registration in Entra ID)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Mailbox the app sends as (e.g. noreply@vernay.com) — needs Mail.Send app permission granted to the app above
MS_SENDER_EMAIL=

# Base URL used to build links in emails (no trailing slash) — must match PORT below
APP_BASE_URL=http://localhost:8080

# Port the app listens on (change if 8080 is already used on this machine)
PORT=8080
